APP_NAME="Election Assistant"
APP_ENV=local
ALLOWED_ORIGINS=*

# Gemini via Google AI Studio or Vertex AI.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Firestore / Firebase Auth.
# Locally, either run `gcloud auth application-default login`
# or point this to a Firebase service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=
FIRESTORE_COLLECTION_PREFIX=election_assistant
FIREBASE_PROJECT_ID=

# Optional polling center simulation.
GOOGLE_MAPS_API_KEY=
